    "better-sqlite3": "^12.6.2",
    "better-sqlite3-session-store": "^0.1.0",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
