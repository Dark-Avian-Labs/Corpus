{
  "name": "corpus",
  "version": "3.0.0",
  "description": "Corpus - game collection tracker",
  "private": true,
  "scripts": {
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:server": "npm run build --workspaces --if-present && tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "build": "npm run build --workspaces --if-present && npm run typecheck && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint server client packages",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "workspaces": [
    "packages/core",
    "packages/games/warframe",
    "packages/games/epic7"
  ],
  "dependencies": {
    "@corpus/core": "3.0.0",
    "@corpus/game-epic7": "3.0.0",
    "@corpus/game-warframe": "3.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "type": "module",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "tar": "^7.5.7",
    "rimraf": "^6.1.2",
    "glob": "^13.0.0",
    "minimatch": "^10.2.2"
  }
}
