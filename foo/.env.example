# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
APP_NAME=Corpus
APP_ID=corpus
APP_SUBDOMAIN=corpus
BASE_DOMAIN=darkavianlabs.com
APP_PUBLIC_BASE_URL=https://corpus.darkavianlabs.com
BASE_HOST=corpus.darkavianlabs.com

# Session — generate a strong random string (32+ characters)
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_COOKIE_NAME=darkavianlabs.corpus.sid

# Behind reverse proxy
TRUST_PROXY=1
SECURE_COOKIES=1
COOKIE_DOMAIN=.darkavianlabs.com

# Central Auth service
AUTH_SERVICE_URL=https://auth.darkavianlabs.com
AUTH_FETCH_TIMEOUT_MS=5000
ALLOWED_APP_ORIGINS=https://auth.darkavianlabs.com,https://corpus.darkavianlabs.com

# Databases
# Shared SQLite mounts (must be absolute paths in deployment)
CENTRAL_DB_PATH=/mnt/dal/shared/auth/central.db
WARFRAME_DB_PATH=./data/warframe.db
EPIC7_DB_PATH=./data/epic7.db
PARAMETRIC_DB_PATH=/mnt/dal/shared/parametric/parametric.db

# Client (build-time)
VITE_APP_NAME=Corpus
VITE_LEGAL_ENTITY_NAME=Dark Avian Labs
VITE_LEGAL_PAGE_URL=/legal
VITE_SEARCH_PLACEHOLDER=Search Corpus...
