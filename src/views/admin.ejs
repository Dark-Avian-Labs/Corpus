<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title><%= appName %> – Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/static/output.css">
</head>
<body class="flex flex-col items-center p-4 md:p-6">
    <% if (typeof art !== 'undefined' && art) { %><div class="bg-art"><%- art %></div><% } %>
    <div class="w-full max-w-5xl relative z-10">
        <%- include('partials/game-admin-header', { pageTitle: appName, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '', corpusAdmin: true }) %>
        <%- include('partials/game-table-open', { columns: [{ name: 'User' }, { name: 'Warframe' }, { name: 'Epic Seven' }, { name: 'Actions' }] }) %>
                <% if (typeof users !== 'undefined' && users && users.length) { %>
                <% users.forEach(function(u) { %>
                <tr data-user-id="<%= u.id %>">
                    <td>
                        <%= u.username %>
                        <% if (u.is_admin) { %><span class="user-admin-tag">admin</span><% } %>
                    </td>
                    <td>
                        <div class="game-toggle">
                            <input type="checkbox" id="wf-<%= u.id %>" data-user-id="<%= u.id %>" data-game-id="warframe"
                                <%= (u.games && u.games.indexOf('warframe') !== -1) ? 'checked' : '' %>>
                            <label for="wf-<%= u.id %>">Access</label>
                        </div>
                    </td>
                    <td>
                        <div class="game-toggle">
                            <input type="checkbox" id="e7-<%= u.id %>" data-user-id="<%= u.id %>" data-game-id="epic7"
                                <%= (u.games && u.games.indexOf('epic7') !== -1) ? 'checked' : '' %>>
                            <label for="e7-<%= u.id %>">Access</label>
                        </div>
                    </td>
                    <td>
                        <% if (typeof currentUserId !== 'undefined' && currentUserId != null && u.id !== currentUserId) { %>
                        <button type="button" class="btn btn-danger btn-delete-user" data-user-id="<%= u.id %>" data-username="<%= u.username %>">Delete</button>
                        <% } else { %>
                        <span class="text-muted text-sm">(you)</span>
                        <% } %>
                    </td>
                </tr>
                <% }); %>
                <% } else { %>
                <tr><td colspan="4" class="text-muted text-center p-6">No users yet. Create one via Register.</td></tr>
                <% } %>
        <%- include('partials/game-table-close') %>
    </div>
    <script src="/static/js/admin.js" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"></script>
</body>
</html>
