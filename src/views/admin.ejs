<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title><%= appName %> - Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <style>
    :root{--text:#e5e7eb;--muted:#9ca3af;--accent:#0ea5e9;--success:#22c55e;--warning:#f59e0b;--danger:#ef4444;--shadow:0 2px 2px rgba(0,0,0,0.15)}
    *{box-sizing:border-box}html,body{height:100%}
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;margin:0;padding:24px;color:var(--text);background:linear-gradient(to bottom,#272b36 0%,#050507 100%);background-size:100% 100%;background-attachment:fixed;min-height:100vh;display:flex;flex-direction:column;align-items:center}
    .bg-art{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);white-space:pre;font-family:'Courier New',monospace;font-size:10px;line-height:1.2;color:rgba(255,255,255,0.05);z-index:0;pointer-events:none;user-select:none}
    .container{width:100%;max-width:1400px;position:relative;z-index:1}
    header{display:flex;gap:16px;flex-wrap:wrap;justify-content:space-between;align-items:center;margin-bottom:20px}
    .header-left{display:flex;align-items:center;gap:16px}
    h1{margin:0;font-size:1.5rem}
    .admin-badge{padding:4px 10px;font-size:12px;font-weight:600;color:var(--warning);background:rgba(245,158,11,0.15);border:1px solid rgba(245,158,11,0.3);border-radius:6px}
    .header-actions{display:flex;gap:12px;align-items:center}
    .btn{padding:8px 16px;font-size:14px;border:1px solid rgba(255,255,255,0.08);border-radius:1rem;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all .2s}
    .btn-primary{color:var(--text);background:var(--accent);border-color:var(--accent)}
    .btn-primary:hover{background:#0284c7}
    .btn-secondary{color:var(--muted);background:transparent}
    .btn-secondary:hover{color:var(--text);border-color:rgba(255,255,255,0.2)}
    .btn-danger{color:var(--danger);background:rgba(239,68,68,0.1);border-color:rgba(239,68,68,0.3)}
    .btn-danger:hover{background:rgba(239,68,68,0.2)}
    .btn-sm{padding:5px 10px;font-size:12px;border-radius:6px}
    .tabs{display:flex;gap:4px;margin-bottom:16px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.08);border-radius:1rem;padding:6px;backdrop-filter:blur(12px)}
    .tab{padding:10px 20px;font-size:14px;color:var(--muted);background:transparent;border:none;border-radius:.75rem;cursor:pointer;transition:all .2s}
    .tab:hover{color:var(--text);background:rgba(255,255,255,0.05)}
    .tab.active{color:var(--text);background:rgba(255,255,255,0.1)}
    .panel{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.08);border-radius:1rem;padding:20px;margin-bottom:20px;backdrop-filter:blur(12px)}
    .panel-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
    .panel-header h2{margin:0;font-size:1.1rem;color:var(--text)}
    .table-container{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.08);border-radius:1rem;overflow:hidden;backdrop-filter:blur(12px)}
    .table-scroll{max-height:calc(100vh - 350px);overflow-y:auto}
    table{width:100%;border-collapse:collapse}
    th,td{padding:12px 16px;text-align:left}
    thead{position:sticky;top:0;z-index:10}
    thead th{background:rgba(30,35,45,0.92);backdrop-filter:blur(20px);color:var(--muted);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.08);text-align:center}
    thead th:first-child,thead th:last-child{text-align:left}
    tbody tr{border-bottom:1px solid rgba(255,255,255,0.04)}
    tbody tr:hover{background:rgba(255,255,255,0.03)}
    .role-cell,.accounts-cell,.created-cell{text-align:center}
    .icon-cell{width:150px;text-align:center}
    .icon-cell img{width:28px;height:28px;vertical-align:middle}
    .stars-cell img{vertical-align:middle;margin-right:2px;width:28px;height:28px}
    .row-actions{display:flex;gap:6px;white-space:nowrap}
    .admin-tag,.user-tag{font-size:11px;padding:2px 6px;border-radius:4px;margin-left:6px}
    .admin-tag{background:rgba(245,158,11,0.2);color:var(--warning)}
    .user-tag{background:rgba(14,165,233,0.2);color:var(--accent)}
    .tab-content{display:none}.tab-content.active{display:block}
    .loading{text-align:center;padding:40px;color:var(--muted)}
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:100;opacity:0;pointer-events:none;transition:opacity .2s}
    .modal-overlay.active{opacity:1;pointer-events:auto}
    .modal{background:#1f2937;border:1px solid rgba(255,255,255,0.1);border-radius:1rem;padding:24px;max-width:500px;width:90%;max-height:90vh;overflow-y:auto}
    .modal h2{margin:0 0 20px;font-size:1.25rem}
    .form-group{margin-bottom:16px}
    .form-group label{display:block;margin-bottom:6px;color:var(--muted);font-size:14px}
    .form-group input,.form-group select{width:100%;padding:10px 12px;font-size:14px;color:var(--text);background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:8px}
    .form-group input:focus,.form-group select:focus{outline:none;border-color:var(--accent)}
    .form-group-inline{display:flex;align-items:center;gap:8px}
    .form-group-inline input[type="checkbox"]{width:18px;height:18px;accent-color:var(--accent)}
    .modal-actions{display:flex;gap:12px;justify-content:flex-end;margin-top:24px}
    .modal-actions button{padding:10px 20px;font-size:14px;border-radius:8px;cursor:pointer}
    .btn-cancel{color:var(--muted);background:transparent;border:1px solid rgba(255,255,255,0.1)}
    .btn-cancel:hover{color:var(--text);border-color:rgba(255,255,255,0.2)}
    .btn-primary{color:var(--text);background:var(--accent);border:none}
    .btn-primary:hover{background:#0284c7}
    .table-scroll::-webkit-scrollbar{width:8px}
    .table-scroll::-webkit-scrollbar-track{background:rgba(255,255,255,0.02)}
    .table-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:4px}
    </style>
</head>
<body>
    <% if (art) { %><div class="bg-art"><%- art %></div><% } %>
    <div class="container">
        <header>
            <div class="header-left">
                <h1><%= appName %></h1>
                <span class="admin-badge">ADMIN</span>
            </div>
            <div class="header-actions">
                <a href="/register" class="btn btn-primary">+ Create User</a>
                <a href="/" class="btn btn-secondary">Back to Tracker</a>
                <form method="POST" action="/logout" style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-secondary">Logout</button>
                </form>
            </div>
        </header>
        <div class="tabs">
            <button class="tab active" data-tab="users">Users</button>
            <button class="tab" data-tab="heroes">Base Heroes</button>
            <button class="tab" data-tab="artifacts">Base Artifacts</button>
        </div>
        <div class="tab-content active" id="users-content">
            <div class="panel">
                <div class="panel-header">
                    <h2>User Management</h2>
                    <button class="btn btn-primary" id="add-user-btn">+ Add User</button>
                </div>
                <div class="table-container">
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr><th>Username</th><th class="role-cell">Role</th><th class="accounts-cell">Accounts</th><th class="created-cell">Created</th><th>Actions</th></tr>
                            </thead>
                            <tbody id="users-table"><tr><td colspan="5" class="loading">Loading...</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="tab-content" id="heroes-content">
            <div class="panel">
                <div class="panel-header">
                    <h2>Base Heroes (Template Data)</h2>
                    <button class="btn btn-primary" id="add-hero-btn">+ Add Hero</button>
                </div>
                <div class="table-container">
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr><th>Name</th><th class="icon-cell">Class</th><th class="icon-cell">Element</th><th>Stars</th><th>Actions</th></tr>
                            </thead>
                            <tbody id="heroes-table"><tr><td colspan="5" class="loading">Loading...</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="tab-content" id="artifacts-content">
            <div class="panel">
                <div class="panel-header">
                    <h2>Base Artifacts (Template Data)</h2>
                    <button class="btn btn-primary" id="add-artifact-btn">+ Add Artifact</button>
                </div>
                <div class="table-container">
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr><th>Name</th><th class="icon-cell">Class</th><th>Stars</th><th>Actions</th></tr>
                            </thead>
                            <tbody id="artifacts-table"><tr><td colspan="4" class="loading">Loading...</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-overlay" id="user-modal">
        <div class="modal">
            <h2>Add User</h2>
            <form id="user-form">
                <div class="form-group"><label for="user-username">Username</label><input type="text" id="user-username" required></div>
                <div class="form-group"><label for="user-password">Password</label><input type="password" id="user-password" required></div>
                <div class="form-group form-group-inline"><input type="checkbox" id="user-is-admin"><label for="user-is-admin">Administrator</label></div>
                <div class="modal-actions"><button type="button" class="btn btn-cancel" id="user-cancel">Cancel</button><button type="submit" class="btn btn-primary">Create</button></div>
            </form>
        </div>
    </div>
    <div class="modal-overlay" id="reset-password-modal">
        <div class="modal">
            <h2>Reset Password</h2>
            <p>User: <span id="reset-username"></span></p>
            <form id="reset-password-form">
                <input type="hidden" id="reset-user-id">
                <div class="form-group"><label for="new-password">New Password</label><input type="password" id="new-password" required></div>
                <div class="modal-actions"><button type="button" class="btn btn-cancel" id="reset-cancel">Cancel</button><button type="submit" class="btn btn-primary">Reset</button></div>
            </form>
        </div>
    </div>
    <div class="modal-overlay" id="hero-modal">
        <div class="modal">
            <h2>Add Base Hero</h2>
            <form id="hero-form">
                <div class="form-group"><label for="hero-name">Name</label><input type="text" id="hero-name" required></div>
                <div class="form-group"><label for="hero-class">Class</label><select id="hero-class"><% heroClasses.forEach(cls => { %><option value="<%= cls %>"><%= classNames[cls] || cls %></option><% }); %></select></div>
                <div class="form-group"><label for="hero-element">Element</label><select id="hero-element"><% elements.forEach(elem => { %><option value="<%= elem %>"><%= elementNames[elem] || elem %></option><% }); %></select></div>
                <div class="form-group"><label for="hero-stars">Stars</label><select id="hero-stars"><option value="3">3</option><option value="4">4</option><option value="5" selected>5</option></select></div>
                <div class="modal-actions"><button type="button" class="btn btn-cancel" id="hero-cancel">Cancel</button><button type="submit" class="btn btn-primary">Add</button></div>
            </form>
        </div>
    </div>
    <div class="modal-overlay" id="artifact-modal">
        <div class="modal">
            <h2>Add Base Artifact</h2>
            <form id="artifact-form">
                <div class="form-group"><label for="artifact-name">Name</label><input type="text" id="artifact-name" required></div>
                <div class="form-group"><label for="artifact-class">Class</label><select id="artifact-class"><% artifactClasses.forEach(cls => { %><option value="<%= cls %>"><%= classNames[cls] || cls %></option><% }); %></select></div>
                <div class="form-group"><label for="artifact-stars">Stars</label><select id="artifact-stars"><option value="3">3</option><option value="4">4</option><option value="5" selected>5</option></select></div>
                <div class="modal-actions"><button type="button" class="btn btn-cancel" id="artifact-cancel">Cancel</button><button type="submit" class="btn btn-primary">Add</button></div>
            </form>
        </div>
    </div>
    <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
    const API_URL = '/api';
    const CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
    const CLASS_NAMES = <%- JSON.stringify(classNames) %>;
    const ELEMENT_NAMES = <%- JSON.stringify(elementNames) %>;
    let users = [], heroes = [], artifacts = [];

    document.addEventListener('DOMContentLoaded', init);

    async function init() {
        document.querySelectorAll('.tab').forEach(tab => { tab.addEventListener('click', () => selectTab(tab.dataset.tab)); });
        document.getElementById('add-hero-btn').addEventListener('click', () => { document.getElementById('hero-name').value = ''; document.getElementById('hero-class').value = 'knight'; document.getElementById('hero-element').value = 'fire'; document.getElementById('hero-stars').value = '5'; document.getElementById('hero-modal').classList.add('active'); document.getElementById('hero-name').focus(); });
        document.getElementById('hero-cancel').addEventListener('click', () => document.getElementById('hero-modal').classList.remove('active'));
        document.getElementById('hero-form').addEventListener('submit', handleAddHero);
        document.getElementById('hero-modal').addEventListener('click', e => { if (e.target.id === 'hero-modal') document.getElementById('hero-modal').classList.remove('active'); });
        document.getElementById('add-artifact-btn').addEventListener('click', () => { document.getElementById('artifact-name').value = ''; document.getElementById('artifact-class').value = 'knight'; document.getElementById('artifact-stars').value = '5'; document.getElementById('artifact-modal').classList.add('active'); document.getElementById('artifact-name').focus(); });
        document.getElementById('artifact-cancel').addEventListener('click', () => document.getElementById('artifact-modal').classList.remove('active'));
        document.getElementById('artifact-form').addEventListener('submit', handleAddArtifact);
        document.getElementById('artifact-modal').addEventListener('click', e => { if (e.target.id === 'artifact-modal') document.getElementById('artifact-modal').classList.remove('active'); });
        document.getElementById('add-user-btn').addEventListener('click', () => { document.getElementById('user-username').value = ''; document.getElementById('user-password').value = ''; document.getElementById('user-is-admin').checked = false; document.getElementById('user-modal').classList.add('active'); document.getElementById('user-username').focus(); });
        document.getElementById('user-cancel').addEventListener('click', () => document.getElementById('user-modal').classList.remove('active'));
        document.getElementById('user-form').addEventListener('submit', handleAddUser);
        document.getElementById('user-modal').addEventListener('click', e => { if (e.target.id === 'user-modal') document.getElementById('user-modal').classList.remove('active'); });
        document.getElementById('reset-cancel').addEventListener('click', () => document.getElementById('reset-password-modal').classList.remove('active'));
        document.getElementById('reset-password-form').addEventListener('submit', handleResetPassword);
        document.getElementById('reset-password-modal').addEventListener('click', e => { if (e.target.id === 'reset-password-modal') document.getElementById('reset-password-modal').classList.remove('active'); });
        await loadUsers();
    }

    function selectTab(tab) {
        document.querySelectorAll('.tab').forEach(t => { t.classList.toggle('active', t.dataset.tab === tab); });
        document.querySelectorAll('.tab-content').forEach(c => { c.classList.toggle('active', c.id === tab + '-content'); });
        if (tab === 'users') loadUsers();
        else if (tab === 'heroes') loadHeroes();
        else if (tab === 'artifacts') loadArtifacts();
    }

    async function loadUsers() {
        const tbody = document.getElementById('users-table');
        tbody.innerHTML = '<tr><td colspan="5" class="loading">Loading...</td></tr>';
        try {
            const r = await fetch(API_URL + '?action=admin_users');
            const d = await r.json();
            if (d.error) { tbody.innerHTML = '<tr><td colspan="5" class="loading" style="color:var(--danger)">' + escapeHtml(d.error) + '</td></tr>'; return; }
            users = d.users;
            if (users.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="loading">No users found.</td></tr>'; return; }
            tbody.innerHTML = users.map(u => `<tr><td>${escapeHtml(u.username)}</td><td class="role-cell">${u.is_admin ? '<span class="admin-tag">Admin</span>' : '<span class="user-tag">User</span>'}</td><td class="accounts-cell">${u.account_count}</td><td class="created-cell">${new Date(u.created_at).toLocaleDateString()}</td><td class="row-actions"><button class="btn btn-sm btn-secondary" data-reset-id="${u.id}" data-reset-name="${escapeHtml(u.username)}">Reset Password</button><button class="btn btn-sm btn-danger" data-del-id="${u.id}" data-del-name="${escapeHtml(u.username)}">Delete</button></td></tr>`).join('');
            tbody.querySelectorAll('[data-reset-id]').forEach(btn => btn.addEventListener('click', () => { document.getElementById('reset-user-id').value = btn.dataset.resetId; document.getElementById('reset-username').textContent = btn.dataset.resetName; document.getElementById('new-password').value = ''; document.getElementById('reset-password-modal').classList.add('active'); document.getElementById('new-password').focus(); }));
            tbody.querySelectorAll('[data-del-id]').forEach(btn => btn.addEventListener('click', () => deleteUser(parseInt(btn.dataset.delId), btn.dataset.delName)));
        } catch (e) { tbody.innerHTML = '<tr><td colspan="5" class="loading" style="color:var(--danger)">Failed to load users</td></tr>'; }
    }

    async function handleAddUser(e) {
        e.preventDefault();
        const username = document.getElementById('user-username').value.trim();
        const password = document.getElementById('user-password').value;
        const isAdmin = document.getElementById('user-is-admin').checked;
        try {
            const r = await fetch(API_URL + '?action=admin_create_user', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ username, password, is_admin: isAdmin }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            document.getElementById('user-modal').classList.remove('active');
            await loadUsers();
        } catch (err) { alert('Failed to create user: ' + err.message); }
    }

    async function handleResetPassword(e) {
        e.preventDefault();
        const userId = document.getElementById('reset-user-id').value;
        const password = document.getElementById('new-password').value;
        try {
            const r = await fetch(API_URL + '?action=admin_reset_password', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ user_id: parseInt(userId), password }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            document.getElementById('reset-password-modal').classList.remove('active');
            alert('Password reset successfully');
        } catch (err) { alert('Failed to reset: ' + err.message); }
    }

    async function deleteUser(userId, username) {
        if (!confirm('Delete user "' + username + '"? This will also delete all their game accounts and data.')) return;
        try {
            const r = await fetch(API_URL + '?action=admin_delete_user', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ user_id: userId }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            await loadUsers();
        } catch (err) { alert('Failed to delete: ' + err.message); }
    }

    async function loadHeroes() {
        const tbody = document.getElementById('heroes-table');
        tbody.innerHTML = '<tr><td colspan="5" class="loading">Loading...</td></tr>';
        try {
            const r = await fetch(API_URL + '?action=admin_base_heroes');
            const d = await r.json();
            if (d.error) { tbody.innerHTML = '<tr><td colspan="5" class="loading" style="color:var(--danger)">' + escapeHtml(d.error) + '</td></tr>'; return; }
            heroes = d.heroes;
            if (heroes.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="loading">No heroes found. Import or add some.</td></tr>'; return; }
            tbody.innerHTML = heroes.map(h => {
                const stars = Array(h.star_rating).fill(0).map(() => '<img src="/icons/star' + h.star_rating + '.png" alt="' + h.star_rating + ' stars">').join('');
                return `<tr><td>${escapeHtml(h.name)}</td><td class="icon-cell"><img src="/icons/${h.class}.png" alt="${CLASS_NAMES[h.class]}" title="${CLASS_NAMES[h.class]}"></td><td class="icon-cell"><img src="/icons/${h.element}.png" alt="${ELEMENT_NAMES[h.element]}" title="${ELEMENT_NAMES[h.element]}"></td><td class="stars-cell">${stars}</td><td class="row-actions"><button class="btn btn-sm btn-danger" data-del-hero-id="${h.id}" data-del-hero-name="${escapeHtml(h.name)}">Delete</button></td></tr>`;
            }).join('');
            tbody.querySelectorAll('[data-del-hero-id]').forEach(btn => btn.addEventListener('click', () => deleteHero(parseInt(btn.dataset.delHeroId), btn.dataset.delHeroName)));
        } catch (e) { tbody.innerHTML = '<tr><td colspan="5" class="loading" style="color:var(--danger)">Failed to load heroes</td></tr>'; }
    }

    async function handleAddHero(e) {
        e.preventDefault();
        const name = document.getElementById('hero-name').value.trim();
        const heroClass = document.getElementById('hero-class').value;
        const element = document.getElementById('hero-element').value;
        const stars = parseInt(document.getElementById('hero-stars').value);
        try {
            const r = await fetch(API_URL + '?action=admin_add_base_hero', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ name, class: heroClass, element, star_rating: stars }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            document.getElementById('hero-modal').classList.remove('active');
            await loadHeroes();
        } catch (err) { alert('Failed to add hero: ' + err.message); }
    }

    async function deleteHero(heroId, heroName) {
        if (!confirm('Delete hero "' + heroName + '"? This will also remove it from all user accounts.')) return;
        try {
            const r = await fetch(API_URL + '?action=admin_delete_base_hero', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ hero_id: heroId }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            await loadHeroes();
        } catch (err) { alert('Failed to delete: ' + err.message); }
    }

    async function loadArtifacts() {
        const tbody = document.getElementById('artifacts-table');
        tbody.innerHTML = '<tr><td colspan="4" class="loading">Loading...</td></tr>';
        try {
            const r = await fetch(API_URL + '?action=admin_base_artifacts');
            const d = await r.json();
            if (d.error) { tbody.innerHTML = '<tr><td colspan="4" class="loading" style="color:var(--danger)">' + escapeHtml(d.error) + '</td></tr>'; return; }
            artifacts = d.artifacts;
            if (artifacts.length === 0) { tbody.innerHTML = '<tr><td colspan="4" class="loading">No artifacts found. Import or add some.</td></tr>'; return; }
            tbody.innerHTML = artifacts.map(a => {
                const stars = Array(a.star_rating).fill(0).map(() => '<img src="/icons/star' + a.star_rating + '.png" alt="' + a.star_rating + ' stars">').join('');
                return `<tr><td>${escapeHtml(a.name)}</td><td class="icon-cell"><img src="/icons/${a.class}.png" alt="${CLASS_NAMES[a.class]}" title="${CLASS_NAMES[a.class]}"></td><td class="stars-cell">${stars}</td><td class="row-actions"><button class="btn btn-sm btn-danger" data-del-artifact-id="${a.id}" data-del-artifact-name="${escapeHtml(a.name)}">Delete</button></td></tr>`;
            }).join('');
            tbody.querySelectorAll('[data-del-artifact-id]').forEach(btn => btn.addEventListener('click', () => deleteArtifact(parseInt(btn.dataset.delArtifactId), btn.dataset.delArtifactName)));
        } catch (e) { tbody.innerHTML = '<tr><td colspan="4" class="loading" style="color:var(--danger)">Failed to load artifacts</td></tr>'; }
    }

    async function handleAddArtifact(e) {
        e.preventDefault();
        const name = document.getElementById('artifact-name').value.trim();
        const artifactClass = document.getElementById('artifact-class').value;
        const stars = parseInt(document.getElementById('artifact-stars').value);
        try {
            const r = await fetch(API_URL + '?action=admin_add_base_artifact', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ name, class: artifactClass, star_rating: stars }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            document.getElementById('artifact-modal').classList.remove('active');
            await loadArtifacts();
        } catch (err) { alert('Failed to add artifact: ' + err.message); }
    }

    async function deleteArtifact(artifactId, artifactName) {
        if (!confirm('Delete artifact "' + artifactName + '"? This will also remove it from all user accounts.')) return;
        try {
            const r = await fetch(API_URL + '?action=admin_delete_base_artifact', { method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN }, body: JSON.stringify({ artifact_id: artifactId }) });
            const d = await r.json();
            if (d.error) { alert('Error: ' + d.error); return; }
            await loadArtifacts();
        } catch (err) { alert('Failed to delete: ' + err.message); }
    }

    function escapeHtml(str) { const d = document.createElement('div'); d.textContent = str; return d.innerHTML; }
    </script>
</body>
</html>
