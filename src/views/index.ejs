<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title><%= appName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/static/output.css">
</head>
<body class="flex flex-col items-center justify-center p-4 md:p-6">
    <% if (typeof art !== 'undefined' && art) { %><div class="bg-art"><%= art %></div><% } %>
    <h1 class="relative z-10 m-0 mb-8 text-3xl"><%= appName %></h1>
    <% if (games && games.length > 0) { %>
    <div class="relative z-10 flex gap-6 flex-wrap justify-center">
        <% games.forEach(function(g) { %>
        <a href="<%= g.safePath %>" class="game-card" style="--color-accent:<%= (g.theme && g.theme.primary) ? g.theme.primary : '#0ea5e9' %>">
            <h2><%= g.name %></h2>
            <p>Open tracker</p>
        </a>
        <% }); %>
    </div>
    <% } else { %>
    <p class="relative z-10 text-muted my-8">No games assigned. Contact an administrator.</p>
    <% } %>
    <div class="relative z-10 mt-8">
        <% if (!csrfToken || (typeof csrfToken === 'string' && csrfToken.trim() === '')) { %><% throw new Error('csrfToken is required for the logout form; do not render index without a valid CSRF token.') %><% } %>
        <form method="POST" action="/logout">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-secondary">Logout</button>
        </form>
    </div>
</body>
</html>
