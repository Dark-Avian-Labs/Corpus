<!DOCTYPE html>
<html lang="en" class="theme-<%= typeof themeMode !== 'undefined' ? themeMode : 'dark' %>">
<head>
    <meta charset="utf-8">
    <title>Change Password · <%= appName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/static/output.css">
</head>
<body class="p-4 md:p-6">
    <% if (typeof art !== 'undefined' && art) { %><div class="bg-art"><%= art %></div><% } %>
    <div class="fixed top-4 right-4 z-20">
        <button type="button" class="icon-toggle-btn" data-theme-toggle aria-label="Toggle theme" title="Toggle theme">
            <span data-theme-icon aria-hidden="true">☀</span>
        </button>
    </div>
    <div class="relative z-10 w-full max-w-xl mx-auto">
        <header class="mb-6">
            <h1 class="brand-lockup">
                <img src="/shared/feathers.png" alt="Dark Avian Labs feather mark" class="brand-lockup__icon">
                <span class="brand-lockup__title"><%= appName %></span>
            </h1>
        </header>

        <section class="glass-panel p-6">
            <h2 class="text-lg font-semibold text-foreground mb-4">Change Password</h2>
            <% if (typeof error !== 'undefined' && error) { %>
                <p class="text-danger mb-3"><%= error %></p>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <p class="text-success mb-3"><%= success %></p>
            <% } %>
            <form method="POST" action="/change-password" class="space-y-3">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <label class="block text-sm text-muted mb-1" for="current_password">Current password</label>
                    <input id="current_password" name="current_password" type="password" class="form-input" required>
                </div>
                <div>
                    <label class="block text-sm text-muted mb-1" for="new_password">New password</label>
                    <input id="new_password" name="new_password" type="password" class="form-input" minlength="8" required>
                </div>
                <div>
                    <label class="block text-sm text-muted mb-1" for="confirm_password">Confirm new password</label>
                    <input id="confirm_password" name="confirm_password" type="password" class="form-input" minlength="8" required>
                </div>
                <div class="flex gap-2 pt-2">
                    <button type="submit" class="btn btn-accent">Update Password</button>
                    <a href="/" class="btn btn-secondary">Back</a>
                </div>
            </form>
        </section>
    </div>
    <script type="module" src="/static/js/theme.js" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"></script>
</body>
</html>
