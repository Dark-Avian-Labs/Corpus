<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Login - <%= appName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="stylesheet" href="/static/output.css">
</head>
<body class="flex items-center justify-center p-4 md:p-6">
    <% if (art) { %><div class="bg-art"><%- art %></div><% } %>
    <div class="relative z-10 w-full max-w-sm">
        <div class="auth-card">
            <h1 class="m-0 text-2xl text-center mb-2"><%= appName %></h1>
            <p class="subtitle">Please log in to continue</p>
            <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
            <% if (typeof dbExists !== 'undefined' && !dbExists) { %>
            <div class="info-box">
                Database not initialized. Run: <code>npm run import</code>
            </div>
            <% } %>
            <form method="POST" action="/login">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% if (typeof next === 'string' && next) { %><input type="hidden" name="next" value="<%= next %>"><% } %>
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required <%= lockedOut ? 'disabled' : '' %> autocomplete="username">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required <%= lockedOut ? 'disabled' : '' %> autocomplete="current-password">
                </div>
                <button type="submit" class="btn btn-primary" <%= lockedOut ? 'disabled' : '' %>>Log In</button>
            </form>
            <% if (lockedOut) { %>
            <div class="lockout-timer">
                Locked out. Try again in <span id="countdown"><% if (lockoutRemaining < 60) { %><%= lockoutRemaining %> second<%= lockoutRemaining !== 1 ? 's' : '' %><% } else { var m = Math.ceil(lockoutRemaining / 60); %><%= m %> minute<%= m !== 1 ? 's' : '' %><% } %></span>.
            </div>
            <script<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
                let remaining = <%= lockoutRemaining %>;
                const countdown = document.getElementById('countdown');
                function formatRemaining(s) {
                    if (s < 60) {
                        return s + ' second' + (s !== 1 ? 's' : '');
                    }
                    var m = Math.ceil(s / 60);
                    return m + ' minute' + (m !== 1 ? 's' : '');
                }
                const interval = setInterval(() => {
                    remaining--;
                    if (remaining <= 0) {
                        clearInterval(interval);
                        location.reload();
                    } else {
                        countdown.textContent = formatRemaining(remaining);
                    }
                }, 1000);
            </script>
            <% } %>
        </div>
    </div>
</body>
</html>
