# Application
APP_NAME=Corpus

# Server
PORT=3000
HOST=127.0.0.1
# SESSION_SECRET: Mandatory — replace the placeholder below with a cryptographically secure
# random secret before any deployment. Generate a long random value (e.g. 32+ bytes / 256-bit)
# using a secure generator (e.g. Node: crypto.randomBytes(32).toString('hex'), or an OS-level
# secret manager). Never commit the real SESSION_SECRET to source control or copy it into this
# example file.
SESSION_SECRET=change-this-to-a-long-random-string

# Behind reverse proxy (HTTPS)
TRUST_PROXY=1
SECURE_COOKIES=1

# Session cookie domain (e.g. .domain.tld so corpus + game subdomains share session)
# COOKIE_DOMAIN=.domain.tld

# Base host for login/game picker (e.g. corpus.domain.tld)
# BASE_HOST=corpus.domain.tld

# Optional: host -> gameId for redirect (e.g. warframe.domain.tld=warframe,epic7.domain.tld=epic7)
# GAME_HOSTS=warframe.domain.tld=warframe,epic7.domain.tld=epic7

# Auth lockout
AUTH_LOCKOUT_FILE=./data/auth-lockout.json
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Databases
CENTRAL_DB_PATH=./data/central.db
# WARFRAME_DB_PATH=./data/warframe.db
# EPIC7_DB_PATH=./data/epic7.db

