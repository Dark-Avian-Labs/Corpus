# Server
PORT=3010
HOST=0.0.0.0
NODE_ENV=production
APP_NAME=Corpus
APP_ID=corpus
APP_SUBDOMAIN=corpus
BASE_DOMAIN=darkavianlabs.com

# Session secret — generate a strong random string (32+ characters)
SESSION_SECRET=change-this-to-a-long-random-string

# Behind reverse proxy
TRUST_PROXY=1
SESSION_COOKIE_NAME=darkavianlabs.corpus.sid

# Central Auth service (new unified auth app)
AUTH_SERVICE_URL=https://auth.darkavianlabs.com
ALLOWED_APP_ORIGINS=https://auth.darkavianlabs.com,https://corpus.darkavianlabs.com

COOKIE_DOMAIN=.darkavianlabs.com

# Databases
CENTRAL_DB_PATH=/var/www/applications/corpus/data/central.db
WARFRAME_DB_PATH=/var/www/applications/corpus/data/warframe.db
EPIC7_DB_PATH=/var/www/applications/corpus/data/epic7.db

# Client
VITE_LEGAL_ENTITY_NAME=Dark Avian Labs
VITE_LEGAL_PAGE_URL=/legal
VITE_SEARCH_PLACEHOLDER=Search Corpus...
