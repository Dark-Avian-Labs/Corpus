<%
  var safeId = function(s) {
    if (typeof s !== 'string') return '';
    return /^[a-zA-Z0-9_-]*$/.test(s) ? s : '';
  };
  var safeClass = function(s) {
    if (typeof s !== 'string') return '';
    return /^[a-zA-Z0-9_-\s]*$/.test(s) ? s : '';
  };
  var validatedWidth = function(s) {
    if (typeof s !== 'string' || !s.trim()) return '';
    var w = s.trim();
    return /^\d+(?:\.\d+)?(?:px|%|em|rem)?$/.test(w) ? w : '';
  };
  var validatedAlign = function(s) {
    if (typeof s !== 'string' || !s.trim()) return '';
    var a = s.toLowerCase().trim();
    return ['left', 'right', 'center', 'justify'].indexOf(a) !== -1 ? a : '';
  };
%>
<div class="table-container">
    <div class="table-scroll"<%= (typeof headerOffset !== 'undefined' && headerOffset) ? ' style="--header-offset: ' + headerOffset + '"' : '' %>>
        <table<%= safeId(typeof tableId !== 'undefined' ? tableId : '') ? ' id="' + safeId(tableId) + '"' : '' %>>
            <thead<%= safeId(typeof theadId !== 'undefined' ? theadId : '') ? ' id="' + safeId(theadId) + '"' : '' %>>
                <tr>
<% if (typeof columns !== 'undefined' && columns && columns.length > 0) { %>
<% columns.forEach(function(col) {
  var vw = validatedWidth(col.width);
  var va = validatedAlign(col.align);
  var style = (vw ? 'width:' + vw : '') + (va ? (vw ? ';' : '') + 'text-align:' + va : '');
  var cls = safeClass(col.className);
%>
                    <th<%= cls ? ' class="' + cls + '"' : '' %><%= style ? ' style="' + style + '"' : '' %>><%= col.name %></th>
<% }); %>
<% } else { %>
                    <th>Loading...</th>
<% } %>
                </tr>
            </thead>
            <tbody<%= safeId(typeof tbodyId !== 'undefined' ? tbodyId : '') ? ' id="' + safeId(tbodyId) + '"' : '' %>>
