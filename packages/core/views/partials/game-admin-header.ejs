<% const base = typeof basePath !== 'undefined' && basePath ? basePath : ''; %>
<header class="flex gap-4 flex-wrap justify-between items-center mb-5">
    <div class="brand-lockup">
        <img src="/shared/feathers.png" alt="Dark Avian Labs feather mark" class="brand-lockup__icon">
        <h1 class="brand-lockup__title"><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof appName !== 'undefined' ? appName : '') %></h1>
        <span class="admin-badge">ADMIN</span>
    </div>
    <div class="flex gap-3 items-center flex-wrap">
        <% if (typeof corpusAdmin !== 'undefined' && corpusAdmin) { %>
        <a href="<%= base + '/register' %>" class="btn btn-primary">+ Create user</a>
        <a href="<%= base + '/' %>" class="btn btn-secondary">Game picker</a>
        <% } else { %>
        <% if (typeof showExtraActions !== 'undefined' && showExtraActions) { %>
        <button type="button" class="btn btn-primary" id="add-btn">+ Add Item</button>
        <div class="search-wrapper">
            <input type="text" class="search-box" id="search" placeholder="Search..." aria-label="Search games">
            <button type="button" class="search-clear" id="search-clear" aria-label="Clear search">&times;</button>
        </div>
        <% } %>
        <% } %>
        <a href="<%= base || '/' %>" class="btn btn-secondary"><%= typeof backToLabel !== 'undefined' ? backToLabel : 'Back to View' %></a>
        <% if (!(typeof corpusAdmin !== 'undefined' && corpusAdmin)) { %>
        <a href="<%= (typeof userManagementUrl !== 'undefined' && userManagementUrl) ? userManagementUrl : '/admin' %>" class="btn btn-secondary">User Management</a>
        <% } %>
        <button type="button" class="icon-toggle-btn" data-theme-toggle aria-label="Toggle theme" title="Toggle theme">
            <span data-theme-icon aria-hidden="true">☀</span>
        </button>
        <a href="/change-password" class="btn btn-secondary">Change Password</a>
        <a href="/logout" class="btn btn-secondary">Logout</a>
    </div>
</header>
