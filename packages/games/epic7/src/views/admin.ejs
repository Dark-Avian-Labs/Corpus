<!DOCTYPE html>
<html lang="en" data-game="epic7"<% if (typeof accentColor !== 'undefined' && accentColor) { %> style="--color-accent:<%= accentColor %>"<% } %>>
<head>
    <meta charset="utf-8">
    <title><%= appName %> - Epic Seven Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <link rel="icon" type="image/x-icon" href="<%= typeof basePath !== 'undefined' && basePath ? basePath + '/favicon.ico' : '/favicon.ico' %>">
    <link rel="stylesheet" href="/static/output.css">
    <style>
    /* Epic7 admin: centre non-edge header columns & flex row-actions */
    thead th { text-align: center; }
    thead th:first-child, thead th:last-child { text-align: left; }
    .row-actions { display: flex; gap: 6px; white-space: nowrap; }
    </style>
</head>
<body class="flex flex-col items-center p-4 md:p-6">
    <% if (art) { %><div class="bg-art"><%- art %></div><% } %>
    <div class="w-full max-w-[1400px] relative z-10">
        <%- include('../partials/game-admin-header', { pageTitle: typeof pageTitle !== 'undefined' ? pageTitle : appName, basePath: typeof basePath !== 'undefined' ? basePath : '', csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '', backToLabel: 'Back to View', showExtraActions: true }) %>
        <div class="tabs" role="tablist">
            <button class="tab active" data-tab="heroes" role="tab" aria-selected="true" aria-controls="heroes-content" tabindex="0">Base Heroes</button>
            <button class="tab" data-tab="artifacts" role="tab" aria-selected="false" aria-controls="artifacts-content" tabindex="-1">Base Artifacts</button>
        </div>
        <div class="tab-content active" id="heroes-content" role="tabpanel">
            <%- include('../partials/game-table-open', { columns: [{ name: 'Name' }, { name: 'Class', className: 'icon-cell' }, { name: 'Element', className: 'icon-cell' }, { name: 'Stars' }, { name: 'Actions' }], tbodyId: 'heroes-table', headerOffset: '350px' }) %>
            <tr><td colspan="5" class="loading">Loading...</td></tr>
            <%- include('../partials/game-table-close') %>
        </div>
        <div class="tab-content" id="artifacts-content" role="tabpanel">
            <%- include('../partials/game-table-open', { columns: [{ name: 'Name' }, { name: 'Class', className: 'icon-cell' }, { name: 'Stars' }, { name: 'Actions' }], tbodyId: 'artifacts-table', headerOffset: '350px' }) %>
            <tr><td colspan="4" class="loading">Loading...</td></tr>
            <%- include('../partials/game-table-close') %>
        </div>
    </div>
    <div class="modal-overlay" id="hero-modal" role="dialog" aria-modal="true" aria-labelledby="e7-add-hero-title">
        <div class="modal">
            <h2 id="e7-add-hero-title">Add Base Hero</h2>
            <form id="hero-form">
                <div class="form-group"><label for="hero-name">Name</label><input type="text" id="hero-name" required></div>
                <div class="form-group"><label for="hero-class">Class</label><select id="hero-class"><% heroClasses.forEach(cls => { %><option value="<%= cls %>"><%= classNames[cls] || cls %></option><% }); %></select></div>
                <div class="form-group"><label for="hero-element">Element</label><select id="hero-element"><% elements.forEach(elem => { %><option value="<%= elem %>"><%= elementNames[elem] || elem %></option><% }); %></select></div>
                <div class="form-group"><label for="hero-stars">Stars</label><select id="hero-stars"><option value="3">3</option><option value="4">4</option><option value="5" selected>5</option></select></div>
                <div class="modal-actions"><button type="button" class="btn btn-cancel" id="hero-cancel">Cancel</button><button type="submit" class="btn btn-primary">Add</button></div>
            </form>
        </div>
    </div>
    <div class="modal-overlay" id="artifact-modal" role="dialog" aria-modal="true" aria-labelledby="e7-add-artifact-title">
        <div class="modal">
            <h2 id="e7-add-artifact-title">Add Base Artifact</h2>
            <form id="artifact-form">
                <div class="form-group"><label for="artifact-name">Name</label><input type="text" id="artifact-name" required></div>
                <div class="form-group"><label for="artifact-class">Class</label><select id="artifact-class"><% artifactClasses.forEach(cls => { %><option value="<%= cls %>"><%= classNames[cls] || cls %></option><% }); %></select></div>
                <div class="form-group"><label for="artifact-stars">Stars</label><select id="artifact-stars"><option value="3">3</option><option value="4">4</option><option value="5" selected>5</option></select></div>
                <div class="modal-actions"><button type="button" class="btn btn-cancel" id="artifact-cancel">Cancel</button><button type="submit" class="btn btn-primary">Add</button></div>
            </form>
        </div>
    </div>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>">window.EPIC7_ADMIN_CONFIG={basePath:<%- typeof basePath !== "undefined" ? JSON.stringify(basePath) : '""' %>,classNames:<%- JSON.stringify(classNames) %>,elementNames:<%- JSON.stringify(elementNames) %>};</script>
    <script src="/static/js/epic7-admin.js" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"></script>
</body>
</html>
