<!DOCTYPE html>
<html lang="en" class="theme-<%= typeof themeMode !== 'undefined' ? themeMode : 'dark' %>" data-game="warframe"<% if (typeof accentColor !== 'undefined' && accentColor) { %> style="--color-accent:<%= accentColor %>"<% } %>>
<head>
    <meta charset="utf-8">
    <title><%= appName %> - Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <link rel="icon" type="image/x-icon" href="<%= typeof basePath !== 'undefined' && basePath ? basePath + '/favicon.ico' : '/favicon.ico' %>">
    <link rel="stylesheet" href="/static/output.css">
    <style>
    /* Warframe admin: centre non-edge columns & show row-actions as flex */
    thead th:not(:first-child):not(:last-child) { text-align: center; }
    .row-actions { display: flex; gap: 6px; white-space: nowrap; }
    </style>
</head>
<body class="flex flex-col items-center p-4 md:p-6">
    <% if (art) { %><div class="bg-art"><%- art %></div><% } %>
    <div class="w-full max-w-[1400px] relative z-10">
        <%- include('../partials/game-admin-header', { pageTitle: appName, basePath: typeof basePath !== 'undefined' ? basePath : '', csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '', backToLabel: 'Back to View', showExtraActions: true }) %>
        <div class="tabs" id="tabs"><div class="loading">Loading tabs...</div></div>
        <%- include('../partials/game-table-open', { columns: [], theadId: 'table-head', tbodyId: 'table-body' }) %>
                <tr><td class="loading">Loading data...</td></tr>
        <%- include('../partials/game-table-close') %>
    </div>
    <div class="modal-overlay" id="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <div class="modal">
            <h2 id="modal-title">Add Item</h2>
            <form id="item-form">
                <input type="hidden" id="form-row-id">
                <div class="form-group">
                    <label for="form-name">Item Name</label>
                    <input type="text" id="form-name" required>
                </div>
                <div id="form-columns"></div>
                <div class="modal-actions">
                    <button type="button" class="btn btn-secondary" id="modal-cancel">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="modal-save">Save</button>
                </div>
            </form>
        </div>
    </div>
    <div class="modal-overlay" id="delete-modal" role="dialog" aria-modal="true" aria-labelledby="wf-admin-delete-title">
        <div class="modal">
            <h2 id="wf-admin-delete-title">Delete Item</h2>
            <p>Are you sure you want to delete "<span id="delete-item-name"></span>"?</p>
            <p class="text-muted text-sm">This action cannot be undone.</p>
            <input type="hidden" id="delete-row-id">
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" id="delete-cancel">Cancel</button>
                <button type="button" class="btn btn-danger" id="delete-confirm">Delete</button>
            </div>
        </div>
    </div>
    <script type="module" src="/static/js/theme.js" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"></script>
    <script nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>">window.WARFRAME_ADMIN_CONFIG={apiUrl:<%- JSON.stringify((typeof basePath !== "undefined" && basePath ? basePath + "/api" : "/api")) %>};</script>
    <script type="module" src="/static/js/warframe-admin.js" nonce="<%= typeof cspNonce !== 'undefined' ? cspNonce : '' %>"></script>
</body>
</html>
