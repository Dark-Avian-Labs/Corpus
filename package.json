{
  "name": "corpus",
  "version": "2.0.0",
  "description": "Corpus – game collection tracker",
  "private": true,
  "scripts": {
    "build": "npm run build --workspaces --if-present && tsc && node scripts/copy-all-views.mjs && npm run build:tailwind && node scripts/copy-tailwind-static.mjs",
    "build:tailwind": "node packages/core/scripts/build-tailwind.mjs",
    "start": "node dist/index.js",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "check-format": "prettier --check ."
  },
  "workspaces": [
    "packages/core",
    "packages/games/warframe",
    "packages/games/epic7"
  ],
  "dependencies": {
    "@corpus/core": "2.0.0",
    "@corpus/game-epic7": "2.0.0",
    "@corpus/game-warframe": "2.0.0",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.0",
    "@types/node": "^25.2.2",
    "typescript": "^5.9.3",
    "@eslint/js": "^9.20.0",
    "@types/better-sqlite3": "^7.6.11",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-promise": "^7.2.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.54.0"
  },
  "type": "module",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "tar": "^7.5.7",
    "rimraf": "^6.1.2",
    "glob": "^13.0.0"
  }
}
