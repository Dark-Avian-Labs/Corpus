{
  "name": "codex",
  "version": "3.5.0",
  "private": true,
  "description": "Codex - game collection tracker",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/games/warframe",
    "packages/games/epic7"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "pnpm run typecheck:server && pnpm run typecheck:client",
    "typecheck:server": "pnpm --filter @codex/core --filter @codex/game-warframe --filter @codex/game-epic7 run --if-present build && tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm --filter @codex/core --filter @codex/game-warframe --filter @codex/game-epic7 run --if-present build && pnpm run typecheck && tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "validate": "node run-quality-checks.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check ."
  },
  "dependencies": {
    "@codex/core": "workspace:*",
    "@codex/game-epic7": "workspace:*",
    "@codex/game-warframe": "workspace:*",
    "@dotenvx/dotenvx": "catalog:",
    "@fontsource-variable/geist": "catalog:",
    "@fontsource-variable/geist-mono": "catalog:",
    "@fontsource-variable/inter": "catalog:",
    "@fontsource-variable/material-symbols-rounded": "catalog:",
    "better-sqlite3": "catalog:",
    "better-sqlite3-session-store": "catalog:",
    "clsx": "catalog:",
    "cookie-parser": "catalog:",
    "csrf-sync": "catalog:",
    "express": "catalog:",
    "express-rate-limit": "catalog:",
    "express-session": "catalog:",
    "helmet": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/vite": "catalog:",
    "@types/better-sqlite3": "catalog:",
    "@types/cookie-parser": "catalog:",
    "@types/express": "catalog:",
    "@types/express-session": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "globals": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "semantic-release": "^25.0.3",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.8"
}
