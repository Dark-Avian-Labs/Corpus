# Application
APP_NAME=Epic7 Collection Tracker

# Server
PORT=3001
SESSION_SECRET=change-this-to-a-long-random-string
TRUST_PROXY=0
SECURE_COOKIES=0

# Auth lockout
AUTH_LOCKOUT_FILE=./data/lockout.json
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Database
SQLITE_DB_PATH=./data/collection.db

# Import
CSV_IMPORT_DIR=./import
CSV_DELIMITER=;

# Default admin (created by import if no users exist)
IMPORT_DEFAULT_ADMIN_USERNAME=admin
# Note: If password contains $, wrap in single quotes to prevent variable expansion
# Example: IMPORT_DEFAULT_ADMIN_PASSWORD='pa$$word@123'
IMPORT_DEFAULT_ADMIN_PASSWORD=admin

# import-account script: which game account to import Heros.csv / Artifacts.csv into
# TARGET_ACCOUNT_ID=1

DEBUG_MODE=false
